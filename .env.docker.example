# =============================================================================
# UTC-eLibrary — Docker (cp .env.docker.example .env rồi docker compose up -d --build)
# =============================================================================

APP_NAME=UTC-eLibrary
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

DEPLOY_PROFILE=vps

APP_PORT=80
RUN_MIGRATIONS=true

APP_LIMIT_PER_MINUTE=60
APP_PASSWORD_DEFAULT=password
SEEDER_DEFAULT_PASSWORD=

BASE_URL=http://localhost
API_ALLOWED_DOMAINS=http://localhost
API_LOG_REQUESTS=false

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# MySQL — service name trong docker-compose.yml
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=utc_elibrary
DB_USERNAME=utc
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=2880
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
MASTER_DATA_CACHE_TTL_MINUTES=10

QUEUE_CONNECTION=redis
DIGITAL_PREVIEW_DISPATCH_SYNC=true
BROADCAST_CONNECTION=log

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=0

FILESYSTEM_DISK=public
MEDIA_DISK=public
MEDIA_SOURCE_DISK=public
DIGITAL_ASSETS_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=60
JWT_REMEMBER_TTL=43200
JWT_REFRESH_TTL=43200
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true

AUTH_GUARD=web

# Azure / SePay — điền khi deploy thật
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"

SEPAY_ACCOUNT_NUMBER=
SEPAY_BANK_NAME=
SEPAY_API_TOKEN=
SEPAY_API_BASE_URL=https://userapi.sepay.vn/v2

# Thông báo & lịch — xem config/notifications.php
NOTIFICATION_UI_POLL_INTERVAL_MS=30000
LOAN_DUE_SOON_DAYS_BEFORE=2
SCHEDULE_LOANS_SYNC_OVERDUE_AT=06:05
SCHEDULE_LOANS_NOTIFY_DUE_SOON_AT=07:00

VITE_APP_NAME="${APP_NAME}"
