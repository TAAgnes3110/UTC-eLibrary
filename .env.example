# =============================================================================
# UTC-eLibrary — mẫu cấu hình (.env)
# Sao chép: cp .env.example .env  rồi php artisan key:generate
# =============================================================================

# --- Ứng dụng ---
APP_NAME=UTC-eLibrary
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# local | vps — bộ quy tắc chạy: docs/HUONG-DAN-CHAY-NHANH.md
DEPLOY_PROFILE=local

APP_LIMIT_PER_MINUTE=60
APP_PASSWORD_DEFAULT=password
SEEDER_DEFAULT_PASSWORD=

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# --- URL API (Postman / frontend) ---
BASE_URL=http://localhost:8000
# Để trống = mọi domain (dev). Production: ghi domain, vd. https://thu-vien.utc.edu.vn
API_ALLOWED_DOMAINS=
API_LOG_REQUESTS=false
# Production: true — chặn mở /api/* trực tiếp trên trình duyệt (SPA vẫn gọi bình thường)
API_HIDE_BROWSER_ACCESS=true
# Production: true — GET /api/health chỉ trả status, không lộ chi tiết DB/cache
API_MINIMAL_HEALTH=true
# Header bảo mật (CSP, X-Frame-Options, …)
SECURITY_HEADERS=true
# CSP: cho phép @iconify/vue tải icon (mặc định đủ 3 host Iconify)
# SECURITY_CSP_CONNECT_SRC=https://api.iconify.design,https://api.unisvg.com,https://api.simplesvg.com

# --- Log ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Cơ sở dữ liệu ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=utc_elibrary
DB_USERNAME=root
DB_PASSWORD=

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=2880
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# HTTP (EC2 IP): để false. HTTPS production: true
SESSION_SECURE_COOKIE=false
# SESSION_SAME_SITE=lax

# Host được Sanctum coi là SPA first-party (cookie session cho /api/*).
# Để trống = tự lấy từ APP_URL + localhost. EC2: SANCTUM_STATEFUL_DOMAINS=3.0.56.220
# SANCTUM_STATEFUL_DOMAINS=

# --- Cache & hàng đợi ---
CACHE_STORE=redis
# CACHE_PREFIX=
MASTER_DATA_CACHE_TTL_MINUTES=10

QUEUE_CONNECTION=database
# true = tạo PDF/PNG xem trước ngay sau upload (không cần queue:work). false = đẩy queue (cần worker trên VPS).
DIGITAL_PREVIEW_DISPATCH_SYNC=true
# Giới hạn PDF upload (KB). Mặc định 51200 (50 MB).
# DIGITAL_PDF_MAX_KB=51200
BROADCAST_CONNECTION=log

# --- Redis (session/cache khi CACHE_STORE=redis) ---
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=0
# REDIS_URL=redis://127.0.0.1:6379

MEMCACHED_HOST=127.0.0.1

# --- Lưu trữ file ---
# Disk mặc định Laravel (ít dùng trực tiếp cho nghiệp vụ)
FILESYSTEM_DISK=public

# Ảnh bìa, avatar, ảnh tin tức, file gửi duyệt (có thể public/R2)
# Xem: docs/deployment/cloudflare-r2-media.md
MEDIA_DISK=public
MEDIA_SOURCE_DISK=public

# PDF tài liệu số gốc + bản xem trước (nên private: local hoặc R2/S3 bucket riêng)
# local → storage/app/private/utc-elibrary/...
DIGITAL_ASSETS_DISK=local

# Xem trước PDF (khi FPDI lỗi với PDF nén): cài qpdf hoặc Ghostscript, để trống = tự tìm trong PATH
# Windows: choco install qpdf  hoặc  choco install ghostscript
# Linux: apt install qpdf ghostscript
# QPDF_BINARY=
# GHOSTSCRIPT_BINARY=
# PNG xem trước trên web: Poppler pdftoppm (winget install oschwartz10612.Poppler)
# PDFTOPPM_BINARY=

# --- AWS S3 (tùy chọn) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Cloudflare R2 (S3-compatible, thường dùng cho MEDIA_DISK) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_URL=
R2_USE_PATH_STYLE_ENDPOINT=false

# --- Thư (dev: log; production: smtp) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- JWT API ---
JWT_SECRET=
JWT_TTL=60
JWT_REMEMBER_TTL=43200
JWT_REFRESH_TTL=43200
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

# --- Auth Laravel (session web) ---
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_PASSWORD_TIMEOUT=10800

# --- Microsoft Azure AD (đăng nhập độc giả, không bắt buộc email @utc.edu.vn) ---
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
# common = mọi tài khoản Microsoft; organizations = chỉ tài khoản công việc/trường
AZURE_TENANT_ID=common
# PROXY=

# --- Laravel Passport (nếu dùng) ---
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# --- SePay — thanh toán tài liệu số ---
SEPAY_ACCOUNT_NUMBER=
SEPAY_BANK_NAME=
SEPAY_API_TOKEN=
SEPAY_API_BASE_URL=https://userapi.sepay.vn/v2
SEPAY_SYNC_LOOKBACK_DAYS=3
SEPAY_PAYMENT_CODE_PREFIX=DL
SEPAY_WEBHOOK_PARSE_PREFIXES=
SEPAY_WEBHOOK_VERIFY_ACCOUNT_NUMBER=false
SEPAY_WEBHOOK_SECRET=
SEPAY_PRICE_LOCK_MINUTES=15
DIGITAL_ORDER_PENDING_MAX_AGE_DAYS=3

NOTIFICATION_UI_POLL_INTERVAL_MS=30000
LOAN_DUE_SOON_DAYS_BEFORE=2
LOAN_DUE_SOON_NOTIFY_ENABLED=true
SCHEDULE_LOANS_SYNC_OVERDUE_AT=06:05
SCHEDULE_LOANS_NOTIFY_DUE_SOON_AT=07:00
SCHEDULE_LIBRARY_CARDS_OVERDUE_LOCKS_AT=01:30
SCHEDULE_DIGITAL_ORDERS_EXPIRE_EVERY_MINUTES=5

# --- Vite / frontend ---
VITE_APP_NAME="${APP_NAME}"
