APP_NAME=UTC-eLibrary
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_LIMIT_PER_MINUTE=60
APP_PASSWORD_DEFAULT=password

BASE_URL=http://localhost

API_ALLOWED_DOMAINS=http://localhost
API_VALIDATE_PERIOD=false

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=utc_elibrary
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=2880
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# Cache: database (default), file, redis (recommended for production)
CACHE_STORE=database
# CACHE_PREFIX=

# Redis (required when CACHE_STORE=redis or QUEUE_CONNECTION=redis)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_CACHE_DB=1

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=43200
JWT_BLACKLIST_ENABLED=true

# Microsoft Azure AD (đăng nhập Microsoft 365)
# Đăng ký app tại https://portal.azure.com → Azure Active Directory → App registrations
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
AZURE_TENANT_ID=organizations

NGROK_AUTHTOKEN=

PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
