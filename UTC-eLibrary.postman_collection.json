    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost" },
    { "key": "DOMAIN", "value": "http://localhost" },
    { "key": "token", "value": "" },
    { "key": "otp", "value": "" },

    { "key": "warehouse_id", "value": "1" },
    { "key": "user_id", "value": "1" },
    { "key": "book_id", "value": "1" },
    { "key": "faculty_id", "value": "1" },
    { "key": "role_id", "value": "1" },
    { "key": "permission_id", "value": "1" },
    { "key": "classification_id", "value": "1" },
    { "key": "classification_detail_id", "value": "1" },
    { "key": "author_id", "value": "1" },
    { "key": "publisher_id", "value": "1" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const domain = pm.variables.get('DOMAIN');",
          "const token = pm.variables.get('token');",
          "",
          "pm.request.headers.upsert({ key: 'domain', value: domain });",
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "pm.request.headers.upsert({ key: 'User-Agent', value: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36' });",
          "",
          "if (token && token.trim().length > 0) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "} else {",
          "  pm.request.headers.remove('Authorization');",
          "}"
        ]
      }
    }
  ],
