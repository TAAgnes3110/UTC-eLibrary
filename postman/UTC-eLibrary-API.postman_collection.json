{
	"info": {
		"_postman_id": "utc-elibrary-api-001",
		"name": "UTC eLibrary API",
		"description": "Collection API cho UTC eLibrary.\n\n1. Biến: base_url, token (JWT sau Login), domain, period (vd: 2025-2026).\n2. Auth: Tab Authorization → Bearer Token → {{token}}.\n3. Headers: Vào Collection → Headers, thêm: domain = {{domain}}, period = {{period}}. (Accept, Content-Type thường đã có.)\n\nChuẩn request: Authorization: Bearer <token>; Accept: application/json; Content-Type: application/json; domain; period.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{"key": "base_url", "value": "https://succinic-unshaped-nery.ngrok-free.dev/api"},
		{"key": "token", "value": ""},
		{"key": "domain", "value": "https://succinic-unshaped-nery.ngrok-free.dev"},
		{"key": "period", "value": "2025-2026"}
	],
	"auth": {
		"type": "bearer",
		"bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]
	},
	"item": [
		{
			"name": "Health",
			"auth": {"type": "noauth"},
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/health",
						"description": "Kiểm tra database, cache. Không cần auth."
					}
				}
			]
		},
		{
			"name": "Auth",
			"auth": {"type": "noauth"},
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"login\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
						},
						"url": "{{base_url}}/v1/auth/login"
					}
				},
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Sinh viên Test\",\n  \"code\": \"12345678\",\n  \"email\": \"sinhvien@example.com\",\n  \"phone\": \"0912345678\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
						},
						"url": "{{base_url}}/v1/auth/register"
					}
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"sinhvien@example.com\",\n  \"otp\": \"123456\"\n}"
						},
						"url": "{{base_url}}/v1/auth/verify-otp"
					}
				},
				{
					"name": "Resend OTP",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"sinhvien@example.com\",\n  \"name\": \"Sinh viên\"\n}"
						},
						"url": "{{base_url}}/v1/auth/resend-otp"
					}
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\",\n  \"password\": \"newpassword\",\n  \"password_confirmation\": \"newpassword\"\n}"
						},
						"url": "{{base_url}}/v1/auth/reset-password"
					}
				},
				{
					"name": "Refresh Token",
					"auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
					"request": {
						"method": "POST",
						"header": [],
						"url": "{{base_url}}/v1/auth/refresh"
					}
				},
				{
					"name": "Get Current User",
					"auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/v1/auth/user"
					}
				},
				{
					"name": "Logout",
					"auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
					"request": {
						"method": "POST",
						"header": [],
						"url": "{{base_url}}/v1/auth/logout"
					}
				}
			]
		},
		{
			"name": "Me (Reader)",
			"item": [
				{
					"name": "Profile - Show",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/v1/me/profile"
					}
				},
				{
					"name": "Profile - Update",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Tên mới\",\n  \"email\": \"email@example.com\",\n  \"phone\": \"0912345678\",\n  \"gender\": \"male\"\n}"
						},
						"url": "{{base_url}}/v1/me/profile"
					}
				},
				{
					"name": "Dashboard",
					"request": {"method": "GET", "url": "{{base_url}}/v1/me/dashboard"}
				},
				{
					"name": "Loans",
					"request": {"method": "GET", "url": "{{base_url}}/v1/me/loans"}
				},
				{
					"name": "Card",
					"request": {"method": "GET", "url": "{{base_url}}/v1/me/card"}
				},
				{
					"name": "Profile Change Requests - Page Data",
					"request": {"method": "GET", "url": "{{base_url}}/v1/me/profile-change-requests/page-data"}
				},
				{
					"name": "Profile Change Requests - Store",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"field\": \"cohort\",\n  \"value_new\": \"K66\"\n}"
						},
						"url": "{{base_url}}/v1/me/profile-change-requests"
					}
				}
			]
		},
		{
			"name": "Master Data",
			"item": [
				{
					"name": "Get Master Data",
					"request": {"method": "GET", "url": "{{base_url}}/v1/master-data"}
				}
			]
		},
		{
			"name": "Admin - Users",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/users"}},
				{"name": "Trash", "request": {"method": "GET", "url": "{{base_url}}/v1/users/trash"}},
				{
					"name": "Store",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"User mới\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password\",\n  \"user_type\": \"MEMBER\",\n  \"code\": \"12345\",\n  \"card_number\": \"12345\"\n}"
						},
						"url": "{{base_url}}/v1/users"
					}
				},
				{"name": "Show", "request": {"method": "GET", "url": "{{base_url}}/v1/users/1"}},
				{
					"name": "Update",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Tên cập nhật\",\n  \"email\": \"user@example.com\",\n  \"user_type\": \"MEMBER\"\n}"
						},
						"url": "{{base_url}}/v1/users/1"
					}
				},
				{"name": "Delete", "request": {"method": "DELETE", "url": "{{base_url}}/v1/users/1"}},
				{"name": "Restore", "request": {"method": "POST", "url": "{{base_url}}/v1/users/restore/1"}},
				{"name": "Force Delete", "request": {"method": "DELETE", "url": "{{base_url}}/v1/users/force/1"}},
				{"name": "Toggle Status", "request": {"method": "POST", "url": "{{base_url}}/v1/users/1/toggle-status"}}
			]
		},
		{
			"name": "Admin - Authors",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/authors"}},
				{"name": "Trash", "request": {"method": "GET", "url": "{{base_url}}/v1/authors/trash"}},
				{
					"name": "Store",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Nguyễn Văn A\",\n  \"nationality\": \"Việt Nam\"\n}"
						},
						"url": "{{base_url}}/v1/authors"
					}
				},
				{"name": "Show", "request": {"method": "GET", "url": "{{base_url}}/v1/authors/1"}},
				{"name": "Update", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"Tên tác giả\", \"nationality\": \"VN\"}"}, "url": "{{base_url}}/v1/authors/1"}},
				{"name": "Delete", "request": {"method": "DELETE", "url": "{{base_url}}/v1/authors/1"}},
				{"name": "Restore", "request": {"method": "POST", "url": "{{base_url}}/v1/authors/restore/1"}},
				{"name": "Force Delete", "request": {"method": "DELETE", "url": "{{base_url}}/v1/authors/force/1"}}
			]
		},
		{
			"name": "Admin - Books",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/books"}},
				{"name": "Trash", "request": {"method": "GET", "url": "{{base_url}}/v1/books/trash"}},
				{"name": "Search Publishers", "request": {"method": "GET", "url": "{{base_url}}/v1/books/search-publishers?q="}},
				{"name": "Search Authors", "request": {"method": "GET", "url": "{{base_url}}/v1/books/search-authors?q="}},
				{"name": "Export", "request": {"method": "GET", "url": "{{base_url}}/v1/books/export"}},
				{"name": "Show", "request": {"method": "GET", "url": "{{base_url}}/v1/books/1"}},
				{"name": "Delete", "request": {"method": "DELETE", "url": "{{base_url}}/v1/books/1"}},
				{"name": "Restore", "request": {"method": "POST", "url": "{{base_url}}/v1/books/restore/1"}},
				{"name": "Force Delete", "request": {"method": "DELETE", "url": "{{base_url}}/v1/books/force/1"}}
			]
		},
		{
			"name": "Admin - Faculties",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/faculties"}},
				{"name": "Show", "request": {"method": "GET", "url": "{{base_url}}/v1/faculties/1"}},
				{"name": "Store", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"Khoa CNTT\", \"code\": \"CNTT\"}"}, "url": "{{base_url}}/v1/faculties"}},
				{"name": "Update", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"Khoa công nghệ thông tin\", \"code\": \"CNTT\"}"}, "url": "{{base_url}}/v1/faculties/1"}},
				{"name": "Delete", "request": {"method": "DELETE", "url": "{{base_url}}/v1/faculties/1"}}
			]
		},
		{
			"name": "Admin - Roles",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/roles"}},
				{"name": "Store", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"editor\"}"}, "url": "{{base_url}}/v1/roles"}},
				{"name": "Show", "request": {"method": "GET", "url": "{{base_url}}/v1/roles/1"}},
				{"name": "Update", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"editor_updated\"}"}, "url": "{{base_url}}/v1/roles/1"}},
				{"name": "Delete", "request": {"method": "DELETE", "url": "{{base_url}}/v1/roles/1"}},
				{"name": "Add Permission", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"permission\": \"users.create\"}"}, "url": "{{base_url}}/v1/roles/1/permissions"}},
				{"name": "Remove Permission", "request": {"method": "DELETE", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"permission\": \"users.create\"}"}, "url": "{{base_url}}/v1/roles/1/permissions"}}
			]
		},
		{
			"name": "Admin - Permissions",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/permissions"}},
				{"name": "Store", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"books.export\"}"}, "url": "{{base_url}}/v1/permissions"}}
			]
		},
		{
			"name": "Admin - Categories",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/categories"}}
			]
		},
		{
			"name": "Admin - Publishers",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/publishers"}}
			]
		},
		{
			"name": "Admin - Profile Change Requests",
			"item": [
				{"name": "Index", "request": {"method": "GET", "url": "{{base_url}}/v1/profile-change-requests?status=pending"}},
				{"name": "Approve", "request": {"method": "POST", "url": "{{base_url}}/v1/profile-change-requests/1/approve"}},
				{"name": "Reject", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"admin_note\": \"Lý do từ chối\"}"}, "url": "{{base_url}}/v1/profile-change-requests/1/reject"}}
			]
		}
	]
}
